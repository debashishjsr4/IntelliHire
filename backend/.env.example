PORT=5000
MONGODB_URI=mongodb://intellihire:intellihire123@localhost:27017/intellihire?authSource=admin
CLIENT_ORIGIN=http://localhost:5173

# Choose "openai", "gemini", or "mock".
# Use "mock" for classroom demos without paid AI credits.
LLM_PROVIDER=openai
# Optional: only used if the main provider fails because quota is exhausted.
# Use "mock" to keep demos running, or "openai"/"gemini" if you have another paid provider configured.
LLM_FALLBACK_PROVIDER=
LLM_TIMEOUT_MS=50000

# OpenAI settings
OPENAI_API_KEY=replace_with_openai_key
OPENAI_MODEL=gpt-4o-mini

# Gemini settings
GEMINI_API_KEY=replace_with_gemini_key
GEMINI_MODEL=gemini-3.0-flash
